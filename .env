OPENAI_API_KEY=your-openai-api-key-here

# Postgres connection used by FastAPI app and pgvector indexer
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/triage

# Embedding configuration for policy vector store
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Langfuse tracing (optional; leave blank to disable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PROJECT_NAME=p1-seafoam-cicada
LANGFUSE_ENVIRONMENT=development

# Use in-memory checkpointer instead of Postgres (set to 1 to enable)
USE_MEMORY_SAVER=
